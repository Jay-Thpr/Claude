{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist-prd-tests",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "tests/prd.test.ts",
    "src/lib/appointment-reminders.ts",
    "src/lib/safety-rules.ts",
    "src/lib/task-flow.ts",
    "src/lib/response-schema.ts"
  ]
}
